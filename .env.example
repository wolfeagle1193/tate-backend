PORT=5000
NODE_ENV=development

# MongoDB Atlas — créer un cluster gratuit sur https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/tate?retryWrites=true&w=majority

# JWT — générer des chaînes aléatoires longues (min 32 caractères)
JWT_SECRET=remplace_par_une_longue_chaine_aleatoire_secrete
JWT_REFRESH_SECRET=remplace_par_une_autre_chaine_aleatoire_differente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Compte administrateur créé au seed
ADMIN_EMAIL=admin@tate.sn
ADMIN_PASSWORD=TonMotDePasseAdmin123!
ADMIN_NOM=Administrateur Taté

# URL du frontend (pour CORS en production)
FRONTEND_URL=http://localhost:5173
